## App config (copy values into your local .env)
## NOTE: Do not commit real secrets.

## Local dev (PostgreSQL on your machine)
DATABASE_URL=postgresql://postgres:password@localhost:5432/notehub
PG_SSL=disable

## Easiest cloud option: Neon (serverless Postgres)
## Paste Neon DATABASE_URL (it usually includes `?sslmode=require`).
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxxxx.us-east-1.aws.neon.tech/notehub?sslmode=require

## AWS RDS / Aurora PostgreSQL (example)
# DATABASE_URL=postgresql://USER:PASSWORD@YOUR-RDS-ENDPOINT:5432/notehub
# PG_SSL=verify-full
# PG_SSL_REJECT_UNAUTHORIZED=true

## Optional: provide CA to validate TLS
## Use ONE of the following:
# PG_SSL_CA_FILE=./certs/rds-ca-bundle.pem
# PG_SSL_CA="-----BEGIN CERTIFICATE-----\\n...\\n-----END CERTIFICATE-----"

## Sessions
## Required in production. Use a long random string.
SESSION_SECRET=change_me
## Optional override. In split frontend/backend deployments this should usually be `none`.
# SESSION_COOKIE_SAME_SITE=none

## Google OAuth (Sign in with Google)
## 1) Create OAuth Client ID (Web application) in Google Cloud Console
## 2) Set Authorized redirect URI to: http://localhost:5000/api/auth/google/callback (dev)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
## Optional: if unset, server auto-derives from request host.
# GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
## Public frontend URL. Used after OAuth completes, especially for Vercel frontend + Render API.
# APP_URL=https://your-frontend.vercel.app

## Security (production)
## Comma-separated list of allowed frontend origins for state-changing API requests (CSRF mitigation).
## For split deployments, include your Vercel frontend origin here.
# ALLOWED_ORIGINS=https://your-domain.com
## Optional explicit host override. Production defaults to 0.0.0.0.
# HOST=0.0.0.0
## Seeding: by default seeds in non-production. Set to false to disable in dev.
# SEED_ON_START=false

## Frontend build-time config (Vercel/static frontend)
## Point the frontend at your Render backend when they are deployed separately.
# VITE_API_BASE_URL=https://your-render-api.onrender.com
